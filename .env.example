DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset to default to SQLite in development.
# Example for PostgreSQL: postgres://user:password@localhost:5432/lecturerhub
DATABASE_URL=

# "open" serves /p/cv/ and /p/schedule/ directly.
# "unlisted" only serves them at the slug-based URLs (/p/cv/<slug>/, /p/schedule/<slug>/).
PUBLIC_PAGES_MODE=open

# Used by the create_default_user management command.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me
